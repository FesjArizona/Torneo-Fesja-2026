{
  "name": "sports-tournaments",
  "version": "0.0.0",
  
"scripts": {
  "ng": "ng",
  "start": "nx serve",
  "build": "nx build",
  "build:api": "tsc -p api/tsconfig.json",
  "start:api": "node api/dist/index.js",
  "dev": "concurrently -n \"ANGULAR,EXPRESS\" -c \"cyan,green\" \"npm run start\" \"npm run start:api\"",
  "start-local:api": "nodemon --watch api/src --ext ts --exec ts-node api/src/index.ts",
  "dev-local": "concurrently -n \"ANGULAR,EXPRESS\" -c \"cyan,green\" \"npm run start\" \"npm run start-local:api\"",
  "setup-env": "node scripts/setup-env.js",
  "build:prod": "npm run setup-env && npm run build && npm run build:api",
  "start:prod": "node api/dist/index.js"
},

  "private": true,
  "dependencies": {
    "@angular/animations": "^16.2.0",
    "@angular/common": "^16.2.0",
    "@angular/compiler": "^16.2.0",
    "@angular/core": "^16.2.0",
    "@angular/forms": "^16.2.0",
    "@angular/platform-browser": "^16.2.0",
    "@angular/platform-browser-dynamic": "^16.2.0",
    "@angular/router": "^16.2.0",
    "@nx/angular": "20.1.4",
    "bcrypt": "^6.0.0",
    "bootstrap": "^5.3.8",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.2.16",
    "@angular-devkit/core": "^16.2.16",
    "@angular-devkit/schematics": "^16.2.16",
    "@angular/cli": "^16.2.16",
    "@angular/compiler-cli": "^16.2.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "20.1.4",
    "@nx/eslint": "22.6.0",
    "@nx/eslint-plugin": "22.6.0",
    "@nx/express": "^22.6.0",
    "@nx/js": "22.6.0",
    "@nx/node": "^22.6.0",
    "@nx/workspace": "20.1.4",
    "@schematics/angular": "^16.2.16",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/cors": "^2.8.19",
    "@types/d3": "^7.4.3",
    "@types/jasmine": "~4.3.0",
    "@types/node": "20.19.9",
    "concurrently": "^9.2.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jasmine-core": "~4.6.0",
    "jsonc-eslint-parser": "^2.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nodemon": "^3.1.14",
    "nx": "20.1.4",
    "prettier": "~3.6.2",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "overrides": {
    "typescript": ">=4.9.3 <5.2.0"
  }
}
